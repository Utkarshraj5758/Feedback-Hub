// Prisma schema for FeedbackHub. Tables use snake_case names via @@map to match
// the data model in CLAUDE.md. Grows one slice at a time — this slice adds the
// two foundational tenant tables only (no relations yet).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())

  @@map("users")
}

enum Plan {
  free
  pro
  team
}

model Organization {
  id                 String   @id @default(cuid())
  name               String
  stripeCustomerId   String?  @unique
  plan               Plan     @default(free)
  subscriptionStatus String?
  createdAt          DateTime @default(now())

  @@map("organizations")
}
