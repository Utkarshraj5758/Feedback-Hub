# Copy to .env and fill in per environment. Real .env files are gitignored.

# --- API (apps/api) ---
# Port the Express server listens on (Stripe CLI in Phase 3 forwards to this).
PORT=4000

# Postgres connection string (Neon). Use the direct (non-pooled) endpoint so
# Prisma migrations work with a single url. Keep sslmode=require for Neon.
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require

# JWT signing secrets. Use long, random, DIFFERENT values per secret
# (e.g. `openssl rand -hex 32`). Access token is short-lived; refresh is long-lived.
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string
